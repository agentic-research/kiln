# Dockerfile.release — slim image from pre-built binary
# Used by CI after the fat binary is already compiled.
# Multi-arch: the correct binary is copied in per platform.

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates libsqlite3-0 \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd -g 65532 mache && useradd -u 65532 -g mache -s /bin/false mache

ARG TARGETARCH
COPY image/linux-${TARGETARCH}/mache /usr/local/bin/mache
RUN chmod +x /usr/local/bin/mache

USER mache
VOLUME /data
VOLUME /source

ENTRYPOINT ["/usr/local/bin/mache", "serve"]
CMD ["/source"]
